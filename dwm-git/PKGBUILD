# Maintainer: Thiago C Silva <librefos@hotmail.com>
pkgname=dwm-git
pkgver=r0
pkgrel=1
pkgdesc='A dynamic window manager for X'
arch=('x86_64')
url='https://dwm.suckless.org/'
license=('MIT')
depends=('libx11' 'libxinerama' 'libxft' 'freetype2' 'terminus-font')
makedepends=('git')
provides=('dwm')
conflicts=('dwm')
source=('git+https://git.suckless.org/dwm')
sha256sums=('SKIP')

pkgver() {
  cd "$srcdir/${pkgname%-git}"
  printf "r%s.%s" "$(git rev-list --count HEAD)" "$(git rev-parse --short HEAD)"
}

prepare() {
  cd "$srcdir/${pkgname%-git}"

  sed -i \
    -e '/showbar\|borderpx/s/=[[:space:]]*[0-9][0-9]*/= 0/'   \
    -e 's/monospace:size=[0-9][0-9]*/Terminus:size=8/g'       \
    -e 's/{[[:space:]]*"1",[^}]*/{ "1", "2", "3", "4", "5" /' \
    -e '/TAGKEYS([[:space:]]*XK_[6-9],[[:space:]]*[5-8])/d'   \
    -e '/"Gimp"/d'                                            \
    -e 's/"Firefox"/"Chromium"/'                              \
    -e '/"Chromium"/s/1[[:space:]]*<<[[:space:]]*8/1 << 4/'   \
    -e '/#define MODKEY/s/Mod1Mask/Mod4Mask/'                 \
    config.def.h

  sed -i \
    -e '/termcmd\[\]/s/$/\nstatic const char *emacscmd[] = { "emacsclient", "-c", "-a", "emacs", NULL };/' \
    -e '/emacscmd/s/$/\nstatic const char *vimcmd[] = { "st", "-e", "vim", NULL };/'                       \
    -e '/XK_p,/s/$/\n\t{ MODKEY, XK_e, spawn, {.v = emacscmd } },/'                                        \
    -e '/XK_e,/s/$/\n\t{ MODKEY, XK_v, spawn, {.v = vimcmd   } },/'                                        \
    config.def.h

  sed -i \
    -e '/^X11INC/s|=.*|= /usr/include/X11|'     \
    -e '/^X11LIB/s|=.*|= /usr/lib/X11|'         \
    -e "/^CFLAGS/s/-Os/$CFLAGS/"                \
    -e "/^LDFLAGS/s/=[[:space:]]*/= $LDFLAGS /" \
    config.mk
}

build() {
  cd "$srcdir/${pkgname%-git}"
  make
}

package() {
  cd "$srcdir/${pkgname%-git}"
  make PREFIX=/usr DESTDIR="$pkgdir" install
  install -Dm644 LICENSE "$pkgdir/usr/share/licenses/$pkgname/LICENSE"
}
