# Maintainer: Thiago C Silva <librefos@hotmail.com>
pkgname=st-git
pkgver=r0
pkgrel=1
pkgdesc="st is a simple terminal implementation for X"
arch=('x86_64')
url="https://st.suckless.org/"
license=('MIT')
depends=('libx11' 'libxft' 'fontconfig' 'freetype2' 'terminus-font')
makedepends=('git')
provides=('st')
conflicts=('st')
source=("git+https://git.suckless.org/st")
sha256sums=('SKIP')

pkgver() {
  cd "$srcdir/${pkgname%-git}"
  printf "r%s.%s" "$(git rev-list --count HEAD)" "$(git rev-parse --short HEAD)"
}

prepare() {
  cd "$srcdir/${pkgname%-git}"

  sed -i '/tic/d' Makefile

  sed -i \
    -e '/showbar/s/=[[:space:]]*[0-9][0-9]*/= 0/'   \
    -e 's/Liberation Mono:pixelsize=[0-9][0-9]*/Terminus:pixelsize=14/g' \
    -e '/cursorshape/s/=[[:space:]]*[0-9]/= 2/' \
    -e '/blinktimeout/s/=[[:space:]]*[0-9][0-9]*/= 0/' \
    -e '/char *shell/s|=[[:space:]]*"/bin/sh"|= "/bin/bash"|' \
    config.def.h

  sed -i "s|^STCFLAGS[[:space:]]*=.*|STCFLAGS = \$(INCS) \$(STCPPFLAGS) \$(CPPFLAGS) \$(CFLAGS) -O2 -march=native -mtune=native|" config.mk
}

build() {
  cd "$srcdir/${pkgname%-git}"
  make X11INC=/usr/include/X11 X11LIB=/usr/lib/X11 \
       FREETYPEINC=/usr/include/freetype2
}

package() {
  cd "$srcdir/${pkgname%-git}"
  make PREFIX=/usr DESTDIR="$pkgdir" install
  install -Dm644 LICENSE "$pkgdir/usr/share/licenses/$pkgname/LICENSE"
}
